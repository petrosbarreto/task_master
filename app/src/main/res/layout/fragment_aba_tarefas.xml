<?xml version="1.0" encoding="utf-8"?>
<!-- Layout compartilhado por PendentesFragment e ConcluidasFragment — Aula 07 -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <!-- Mensagem quando não há tarefas nessa aba -->
    <TextView
        android:id="@+id/tvVazioAba"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nenhuma tarefa aqui."
        android:textSize="16sp"
        android:textColor="#94A3B8"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lista de tarefas da aba -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAba"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

